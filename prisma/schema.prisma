generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id           Int                @id @default(autoincrement()) @map("empresa_id")
  rif          String             @map("empresa_rif") @db.VarChar
  nombre       String             @map("empresa_nombre") @db.VarChar
  activo       Boolean            @map("empresa_estatus")
  tipo         String             @map("empresa_tipo") @db.VarChar
  createdAt    DateTime?          @map("created_at") @db.Timestamp(6)
  modulos      EmpresaModulo[]
  submodulos   EmpresaSubmodulo[]
  recibos      Recibo[]
  roles        Role[]
  siniestro    Siniestro[]
  usuarios     Usuario[]
  productos    Producto[]
  planes       Plan[]
  cotizaciones Cotizacion[]
  ocrs         Ocr[]
  pagos        Pago[]
  pagoMetodos  PagoMetodo[]
  emisiones    Emision[]
  productConfigs ProductConfig[]
  feeTransaccion Decimal?         @default(0) @map("empresa_fee_transaccion") @db.Decimal(10, 2)

  @@map("empresa")
}

model Modulo {
  id         Int             @id @default(autoincrement()) @map("modulo_id")
  nombre     String          @map("modulo_nombre") @db.VarChar
  activo     Boolean         @map("modulo_estatus")
  createdAt  DateTime?       @map("created_at") @db.Timestamp(6)
  empresas   EmpresaModulo[]
  submodulos Submodulo[]

  @@map("modulo")
}

model Submodulo {
  id       Int                @id @default(autoincrement()) @map("submodulo_id")
  nombre   String             @map("submodulo_nombre") @db.VarChar
  url      String?            @map("submodulo_url") @db.VarChar(2048)
  activo   Boolean            @map("submodulo_estatus")
  moduloId Int                @map("submodulo_modulo_id")
  modulo   Modulo             @relation(fields: [moduloId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_submodulo_modulo")
  empresas EmpresaSubmodulo[]

  @@map("submodulo")
}

model EmpresaSubmodulo {
  id          Int       @id @default(autoincrement()) @map("emsm_id")
  empresaId   Int       @map("emsm_empresa_id")
  submoduloId Int       @map("emsm_submodulo_id")
  activo      Boolean   @map("emsm_estatus")
  tenantToken String?   @map("emsm_tenant_token") @db.Text
  createdAt   DateTime? @map("emsm_created_at") @db.Timestamp(6)

  empresa   Empresa   @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_empresa_submodulo_empresa")
  submodulo Submodulo @relation(fields: [submoduloId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_empresa_submodulo_submodulo")

  @@unique([empresaId, submoduloId])
  @@map("empresa_submodulo")
}

model EmpresaModulo {
  id        Int          @id @default(autoincrement()) @map("emmo_id")
  empresaId Int          @map("emmo_empresa_id")
  moduloId  Int          @map("emmo_modulo_id")
  token     String?      @map("emmo_token") @db.VarChar
  activo    Boolean      @map("emmo_estatus")
  createdAt DateTime?    @map("emmo_created_at") @db.Timestamp(6)
  empresa   Empresa      @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_empresa_modulo_empresa")
  modulo    Modulo       @relation(fields: [moduloId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_empresa_modulo_modulo")
  permisos  Permission[]

  @@map("empresa_modulo")
}

model Role {
  id        Int          @id @default(autoincrement()) @map("rol_id")
  nombre    String       @map("rol_nombre") @db.VarChar
  activo    Boolean      @map("rol_estatus")
  empresaId Int          @map("rol_empresa_id")
  empresa   Empresa      @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rol_empresa")
  permisos  Permission[]
  usuarios  Usuario[]

  @@unique([nombre, empresaId])
  @@map("rol")
}

model Permission {
  id              Int           @id @default(autoincrement()) @map("romo_id")
  roleId          Int           @map("romo_rol_id")
  empresaModuloId Int           @map("romo_emmo_id")
  activo          Boolean?      @map("romo_estatus")
  empresaModulo   EmpresaModulo @relation(fields: [empresaModuloId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rol_modulo_empresa_modulo")
  role            Role          @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rol_modulo_rol")

  @@map("rol_modulo")
}

// Nueva tabla para granularidad (CRUD) que intentaremos crear
model RolePermissionDetail {
  id          Int     @id @default(autoincrement())
  roleId      Int
  moduloId    Int // ID del módulo global
  submoduloId Int? // Opcional para submódulos
  canCreate   Boolean @default(false)
  canRead     Boolean @default(true)
  canUpdate   Boolean @default(false)
  canDelete   Boolean @default(false)

  @@map("rol_permiso_detalle")
}

model Recibo {
  id                     Int       @id @default(autoincrement()) @map("recibo_id")
  numero                 Int       @map("recibo_numero")
  estatus                Boolean   @map("recibo_estatus")
  monto                  Decimal   @map("recibo_monto") @db.Decimal
  fechaDesde             DateTime  @map("recibo_fecha_desde") @db.Timestamp(6)
  fechaHasta             DateTime  @map("recibo_fecha_hasta") @db.Timestamp(6)
  recibo_fecha_pago      DateTime? @db.Timestamp(6)
  recibo_fecha_anulacion DateTime? @db.Timestamp(6)
  empresaId              Int       @map("recibo_empresa_id")
  empresa                Empresa   @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_recibo_empresa")

  @@map("recibo")
}

model Siniestro {
  id                   Int       @id @default(autoincrement()) @map("siniestro_id")
  numero               Int       @map("siniestro_numero")
  fechaOcurrencia      DateTime  @map("siniestro_fecha_ocurrencia") @db.Timestamp(6)
  fechaDeclaracion     DateTime? @map("siniestro_fecha_declaracion") @db.Timestamp(6)
  siniestro_fecha_pago DateTime? @db.Timestamp(6)
  estatus              DateTime? @map("siniestro_estatus") @db.Timestamp(6)
  recibo_empresa_id    Int
  empresa              Empresa   @relation(fields: [recibo_empresa_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_siniestro_empresa")

  @@map("siniestro")
}

model Usuario {
  id        Int      @id @default(autoincrement()) @map("usuario_id")
  email     String   @unique @map("usuario_email") @db.VarChar
  password  String   @map("usuario_password") @db.VarChar
  nombre    String   @map("usuario_nombre") @db.VarChar
  empresaId Int      @map("usuario_empresa_id")
  roleId    Int      @map("usuario_role_id")
  activo    Boolean  @default(true) @map("usuario_estatus")
  createdAt DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])

  @@map("usuario")
}

model migrations {
  id        Int    @id(map: "PK_8c82d7f526340ab734260ea46be") @default(autoincrement())
  timestamp BigInt
  name      String @db.VarChar
}

// ─── Módulos del flujo de suscripción (OCR · Formulario · Planes · Pago · Emisión) ───
// Multi-tenant: todo cuelga de `empresa`. Los FK a `cotizacion` son opcionales
// para que cada módulo pueda operar por separado o encadenado.

model Producto {
  id           Int          @id @default(autoincrement()) @map("producto_id")
  nombre       String       @map("producto_nombre") @db.VarChar
  empresaId    Int          @map("producto_empresa_id")
  createdAt    DateTime     @default(now()) @map("producto_created_at") @db.Timestamp(6)
  empresa      Empresa      @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_producto_empresa")
  planes       Plan[]
  cotizaciones Cotizacion[]

  @@map("producto")
}

model Plan {
  id           Int          @id @default(autoincrement()) @map("plan_id")
  nombre       String       @map("plan_nombre") @db.VarChar
  productoId   Int          @map("plan_producto_id")
  empresaId    Int          @map("plan_empresa_id")
  createdAt    DateTime     @default(now()) @map("plan_created_at") @db.Timestamp(6)
  producto     Producto     @relation(fields: [productoId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_plan_producto")
  empresa      Empresa      @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_plan_empresa")
  cotizaciones Cotizacion[]

  @@map("plan")
}

model Cotizacion {
  id         Int       @id @default(autoincrement()) @map("cotizacion_id")
  empresaId  Int       @map("cotizacion_empresa_id")
  productoId Int?      @map("cotizacion_producto_id")
  planId     Int?      @map("cotizacion_plan_id")
  estado     String    @default("borrador") @map("cotizacion_estado") @db.VarChar
  jsonData   Json      @map("cotizacion_json_data") @db.JsonB
  createdAt  DateTime  @default(now()) @map("cotizacion_created_at") @db.Timestamp(6)
  updatedAt  DateTime? @updatedAt @map("cotizacion_updated_at") @db.Timestamp(6)
  empresa    Empresa   @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cotizacion_empresa")
  producto   Producto? @relation(fields: [productoId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cotizacion_producto")
  plan       Plan?     @relation(fields: [planId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cotizacion_plan")
  ocrs       Ocr[]
  pagos      Pago[]
  emisiones  Emision[]

  @@map("cotizacion")
}

model Ocr {
  id            Int         @id @default(autoincrement()) @map("ocr_id")
  empresaId     Int         @map("ocr_empresa_id")
  cotizacionId  Int?        @map("ocr_cotizacion_id")
  tipoDocumento String      @map("ocr_tipo_documento") @db.VarChar
  rutaDocumento String      @map("ocr_ruta_documento") @db.VarChar
  jsonData      Json?       @map("ocr_json_data") @db.JsonB
  createdAt     DateTime    @default(now()) @map("ocr_created_at") @db.Timestamp(6)
  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ocr_empresa")
  cotizacion    Cotizacion? @relation(fields: [cotizacionId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ocr_cotizacion")

  @@map("ocr")
}

model PagoMetodo {
  id        Int      @id @default(autoincrement()) @map("pago_metodo_id")
  nombre    String   @map("pago_metodo_nombre") @db.VarChar
  empresaId Int?     @map("pago_metodo_empresa_id")
  empresa   Empresa? @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pago_metodo_empresa")
  pagos     Pago[]

  @@map("pago_metodo")
}

model Pago {
  id              Int         @id @default(autoincrement()) @map("pago_id")
  empresaId       Int         @map("pago_empresa_id")
  cotizacionId    Int?        @map("pago_cotizacion_id")
  metodoId        Int         @map("pago_metodo_id")
  referenciaBanco String      @map("pago_referencia_banco") @db.VarChar
  monto           Decimal     @map("pago_monto") @db.Decimal(18, 2)
  moneda          String      @default("VES") @map("pago_moneda") @db.Char(3)
  estado          String      @default("pendiente") @map("pago_estado") @db.VarChar
  bancoOrigen     String?     @map("pago_banco_origen") @db.VarChar
  telefonoOrigen  String?     @map("pago_telefono_origen") @db.VarChar
  fechaPago       DateTime    @map("pago_fecha_pago") @db.Timestamp(6)
  respuestaJson   Json?       @map("pago_respuesta_json") @db.JsonB
  createdAt       DateTime    @default(now()) @map("pago_created_at") @db.Timestamp(6)
  empresa         Empresa     @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pago_empresa")
  cotizacion      Cotizacion? @relation(fields: [cotizacionId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pago_cotizacion")
  metodo          PagoMetodo  @relation(fields: [metodoId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pago_metodo")
  emisiones       Emision[]

  @@unique([empresaId, referenciaBanco], map: "uq_pago_empresa_referencia")
  @@map("pago")
}

model Emision {
  id           Int        @id @default(autoincrement()) @map("emision_id")
  empresaId    Int        @map("emision_empresa_id")
  cotizacionId Int        @map("emision_cotizacion_id")
  pagoId       Int?       @map("emision_pago_id")
  polizaNumero String     @map("emision_poliza_numero") @db.VarChar
  estado       String     @default("emitida") @map("emision_estado") @db.VarChar
  jsonData     Json?      @map("emision_json_data") @db.JsonB
  createdAt    DateTime   @default(now()) @map("emision_created_at") @db.Timestamp(6)
  empresa      Empresa    @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_emision_empresa")
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_emision_cotizacion")
  pago         Pago?      @relation(fields: [pagoId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_emision_pago")

  @@map("emision")
}

// ─── Configuración paramétrica de flujo por producto ────────────────────────
// Permite activar/desactivar campos y documentos sin tocar código.
// Si no existe config para una empresa/producto/modulo, los módulos
// usan su configuración hardcoded por defecto (fallback seguro).

model ProductConfig {
  id         Int      @id @default(autoincrement()) @map("product_config_id")
  empresaId  Int      @map("product_config_empresa_id")
  producto   String   @map("product_config_producto") @db.VarChar  // "rcv" | "funerario"
  modulo     String   @map("product_config_modulo") @db.VarChar    // "ocr" | "formulario" | "pagos"
  configJson Json     @map("product_config_json") @db.JsonB
  createdAt  DateTime @default(now()) @map("product_config_created_at") @db.Timestamp(6)
  updatedAt  DateTime @updatedAt @map("product_config_updated_at") @db.Timestamp(6)
  empresa    Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade, map: "fk_product_config_empresa")

  @@unique([empresaId, producto, modulo], map: "uq_product_config")
  @@map("product_config")
}
