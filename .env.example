# 🌐 Servidor
PORT=3021
NODE_ENV=development

# 🔑 Seguridad
# Global API Key para acceso a la infraestructura
API_KEY=

# Llave de encriptación simétrica para JWT (32 caracteres exactos)
ENCRYPTION_KEY=
JWT_SECRET=super_secret_jwt_key

# Llave para firmar tokens de acceso de submodulos (min 32 caracteres)
# Distinta de JWT_SECRET — se usa solo para tenant access tokens
TENANT_TOKEN_SECRET=

# 🗄️ Base de Datos (PostgreSQL)
DATABASE_URL="postgresql://usuario:password@localhost:5432/exelixi_nexus?schema=public"

# 📡 Observabilidad (Sentry)
# Obtén tu DSN en sentry.io
SENTRY_DSN=https://tu_key@sentry.io/proyecto
SENTRY_ORG=tu_organizacion
SENTRY_PROJECT=exelixi-nexus-backend

# 📈 Logging
# Nivel de log: error, warn, info, debug
LOG_LEVEL=info

# Forzar salida de logs por consola (stdout / pm2 logs) aunque NODE_ENV=production.
# Útil en servidores prod-like de desarrollo. No relaja el resto de seguridad.
# LOG_CONSOLE=true

# 🌐 CORS — orígenes extra (separados por coma). Los de La Mundial también se permiten por sufijo de dominio.
# ALLOWED_ORIGINS=https://qasys2000.lamundialdeseguros.com,http://192.168.10.215:4200
